{
  "manifest_version": 3,
  "name": "Bring Back Twitter",
  "version": "1.1",
  "description": "XをかつてのTwitterの見た目に戻します（ロゴ・青い鳥・配色・テキスト、プレミアム勧誘やGrokの非表示）",
  "icons": {
    "16": "icons/icon16.png",
    "32": "icons/icon32.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "content_scripts": [
    {
      "matches": ["*://x.com/*", "*://twitter.com/*"],
      "js": ["content.js"],
      "css": ["styles.css"],
      "run_at": "document_idle"
    }
  ]
}
