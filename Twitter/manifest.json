{
  "manifest_version": 3,
  "name": "Twitter Look for X",
  "version": "1.0",
  "description": "XサイトにTwitterの見た目を被せます（ロゴ・配色・テキスト）",
  "content_scripts": [
    {
      "matches": ["*://x.com/*", "*://twitter.com/*"],
      "js": ["content.js"],
      "css": ["styles.css"],
      "run_at": "document_idle"
    }
  ]
}
